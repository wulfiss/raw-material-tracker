
{
  "$schema": "https://opencode.ai/config.json",
   

  "plugin": ["@sveltejs/opencode"],

  "model": "qwen3-coder-30b-a3b-instruct",

  "agent": {

    "build": {
      "model": "qwen3-coder-30b-a3b-instruct",
      "temperature": 0.7
    },


    "explore": {
      "model": "omnicoder-9b@q4_k_s",
      "temperature": 0.3,
      "maxTokens": 2048
    },


    "scout": {
      "model": "omnicoder-9b@q4_k_s",
      "temperature": 0.3,
      "maxTokens": 2048
    },


    "general": {
      "model": "omnicoder-9b@q4_k_s",
      "temperature": 0.3,
      "maxTokens": 2048
    }
  },

  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF",
      "enabled": true
    }
  }
}