{
  "$schema": "https://opencode.ai/config.json",

  "plugin": ["@sveltejs/opencode"],

  "model": "qwen/qwen3.6-27b",

  "agent": {
    "build": {
      "model": "qwen/qwen3.6-27b",
      "temperature": 0.2
    },
    "explore": {
      "model": "qwen/qwen3.6-27b",
      "temperature": 0.3
    },
    "scout": {
      "model": "qwen/qwen3.6-27b",
      "temperature": 0.3
    },
    "general": {
      "model": "qwen/qwen3.6-27b",
      "temperature": 0.3
    }
  },


  "mcp": {
    "svelte": {
      "type": "local",
      "command": ["npx", "-y", "@sveltejs/mcp"],
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "http://127.0.0.1:54321/mcp",
      "enabled": true
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "enabled": true
    }
  }
}