{
  "$schema": "https://opencode.ai/config.json",

  "plugin": ["@sveltejs/opencode"],

  "model": "local/qwen3.6-35b-a3b",

  "agent": {
    "build": {
      "model": "local/qwen3.6-35b-a3b",
      "temperature": 0.2
    },
    "explore": {
      "model": "local/qwen3.6-35b-a3b",
      "temperature": 0.3
    },
    "scout": {
      "model": "local/qwen3.6-35b-a3b",
      "temperature": 0.3
    },
    "general": {
      "model": "local/qwen3.6-35b-a3b",
      "temperature": 0.3
    }
  },


  "mcp": {
    "svelte": {
      "type": "local",
      "command": ["npx", "-y", "@sveltejs/mcp"],
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF",
      "enabled": true
    }
  }
}